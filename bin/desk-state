#!/usr/bin/env node

// Desk state management — single command for all .desk/ file operations
// Usage:
//   desk-state hire <agent-slug>
//   desk-state fire <agent-slug> [reason]
//   desk-state update <agent-slug> <key> <value>
//   desk-state show

import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const DESK = path.join(__dirname, '..', '.desk');
const STATE = path.join(DESK, 'state.json');
const RISK = path.join(DESK, 'risk.json');
const BRIEFINGS = path.join(DESK, 'briefings');

function ensureDirs() {
  fs.mkdirSync(DESK, { recursive: true });
  fs.mkdirSync(BRIEFINGS, { recursive: true });
}

function readState() {
  try {
    return JSON.parse(fs.readFileSync(STATE, 'utf8'));
  } catch {
    return {
      desk: { created: today(), last_session: today(), mode: 'paper' },
      agents: {},
      exchanges: {}
    };
  }
}

function writeState(state) {
  state.desk.last_session = today();
  fs.writeFileSync(STATE, JSON.stringify(state, null, 2) + '\n');
}

function readRisk() {
  try {
    return JSON.parse(fs.readFileSync(RISK, 'utf8'));
  } catch {
    return { risk_manager_hired: false, parameters: {}, warnings: [] };
  }
}

function writeRisk(risk) {
  fs.writeFileSync(RISK, JSON.stringify(risk, null, 2) + '\n');
}

function today() {
  return new Date().toISOString().slice(0, 10);
}

function hire(slug) {
  ensureDirs();
  const state = readState();
  const briefingPath = `.desk/briefings/${slug}.md`;
  const briefingFull = path.join(DESK, 'briefings', `${slug}.md`);
  const skillPath = `skills/${slug}/SKILL.md`;

  // Check if skill exists
  const skillFull = path.join(__dirname, '..', skillPath);
  if (!fs.existsSync(skillFull)) {
    console.error(`Error: No skill found at ${skillPath}`);
    process.exit(1);
  }

  const wasActive = state.agents[slug]?.status === 'active';

  // Update agent state
  state.agents[slug] = {
    ...state.agents[slug],
    status: 'active',
    hired: state.agents[slug]?.hired || today(),
    skill: skillPath,
    briefing: briefingPath,
    assets_covered: state.agents[slug]?.assets_covered || [],
    last_action: wasActive
      ? state.agents[slug]?.last_action
      : 'Hired — awaiting first assignment'
  };
  writeState(state);

  // Create briefing if it doesn't exist
  const isNew = !fs.existsSync(briefingFull);
  if (isNew) {
    const name = slug.split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ');
    fs.writeFileSync(briefingFull, `# ${name} — Briefing Book\n\n## Status\n- **Hired:** ${today()}\n\n## Analyses\n_No analyses yet._\n\n## Open Questions\n_None._\n`);
  }

  // Update risk.json if hiring risk-manager
  if (slug === 'risk-manager') {
    const risk = readRisk();
    risk.risk_manager_hired = true;
    writeRisk(risk);
  }

  // Output summary as JSON for Claude to use
  const result = {
    action: 'hired',
    agent: slug,
    returning: !isNew,
    briefing_exists: !isNew,
    briefing_path: briefingPath,
    skill_path: skillPath,
    active_agents: Object.entries(state.agents)
      .filter(([, a]) => a.status === 'active')
      .map(([k]) => k),
    risk_manager_active: state.agents['risk-manager']?.status === 'active'
  };
  console.log(JSON.stringify(result, null, 2));
}

function fire(slug, reason) {
  const state = readState();
  if (!state.agents[slug] || state.agents[slug].status !== 'active') {
    console.error(`Error: ${slug} is not currently active`);
    process.exit(1);
  }

  state.agents[slug].status = 'fired';
  state.agents[slug].fired_date = today();
  state.agents[slug].fire_reason = reason || 'underperformance';
  writeState(state);

  // Update risk.json if firing risk-manager
  if (slug === 'risk-manager') {
    const risk = readRisk();
    risk.risk_manager_hired = false;
    writeRisk(risk);
  }

  const tradingAgents = Object.entries(state.agents)
    .filter(([k, a]) => a.status === 'active' && k !== 'risk-manager');

  const result = {
    action: 'fired',
    agent: slug,
    reason: reason || 'underperformance',
    remaining_agents: Object.entries(state.agents)
      .filter(([, a]) => a.status === 'active')
      .map(([k]) => k),
    warning: slug === 'risk-manager' && tradingAgents.length > 0
      ? `Risk Manager fired with ${tradingAgents.length} trading agents still active!`
      : null
  };
  console.log(JSON.stringify(result, null, 2));
}

function update(slug, key, value) {
  const state = readState();
  if (!state.agents[slug]) {
    console.error(`Error: ${slug} not found`);
    process.exit(1);
  }
  // Try to parse JSON values
  try { value = JSON.parse(value); } catch {}
  state.agents[slug][key] = value;
  writeState(state);
  console.log(JSON.stringify({ action: 'updated', agent: slug, [key]: value }));
}

function show() {
  const state = readState();
  console.log(JSON.stringify(state, null, 2));
}

function readOrders() {
  const ordersPath = path.join(DESK, 'orders.json');
  try {
    return JSON.parse(fs.readFileSync(ordersPath, 'utf8'));
  } catch {
    return [];
  }
}

function health(format) {
  const state = readState();
  const risk = readRisk();
  const orders = readOrders();

  const activeAgents = Object.entries(state.agents)
    .filter(([, a]) => a.status === 'active')
    .map(([slug]) => slug);

  const firedAgents = Object.entries(state.agents)
    .filter(([, a]) => a.status === 'fired')
    .map(([slug, a]) => ({ slug, reason: a.fire_reason, date: a.fired_date }));

  // Order metrics
  const filled = orders.filter(o => o.status === 'filled');
  const rejected = orders.filter(o => o.status === 'rejected');
  const wins = filled.filter(o => (o.pnl || 0) > 0);
  const losses = filled.filter(o => (o.pnl || 0) < 0);
  const totalPnl = filled.reduce((sum, o) => sum + (o.pnl || 0), 0);
  const winRate = filled.length > 0 ? wins.length / filled.length : 0;

  // Drawdown from equity curve
  let maxDrawdown = 0;
  let equity = 0;
  let peak = 0;
  for (const o of filled) {
    equity += o.pnl || 0;
    if (equity > peak) peak = equity;
    const dd = peak > 0 ? (peak - equity) / peak : 0;
    if (dd > maxDrawdown) maxDrawdown = dd;
  }

  // Rule violations
  const violations = [];
  if (!risk.risk_manager_hired && activeAgents.length > 0) {
    violations.push('No risk manager active while trading agents are hired');
  }
  if (rejected.length > 0) {
    violations.push(`${rejected.length} order(s) rejected`);
  }
  if (maxDrawdown > (risk.parameters?.max_drawdown || 0.05)) {
    violations.push(`Max drawdown ${(maxDrawdown * 100).toFixed(1)}% exceeds limit`);
  }

  const report = {
    date: today(),
    mode: state.desk?.mode || 'paper',
    active_agents: activeAgents,
    fired_agents: firedAgents,
    metrics: {
      total_orders: orders.length,
      filled: filled.length,
      rejected: rejected.length,
      total_pnl: Math.round(totalPnl * 100) / 100,
      win_rate: Math.round(winRate * 1000) / 10,
      max_drawdown: Math.round(maxDrawdown * 1000) / 10,
      wins: wins.length,
      losses: losses.length,
    },
    violations,
    risk_parameters: risk.parameters || {},
  };

  // Plain-English interpretation
  const lines = [];
  lines.push(`# Desk Health Report — ${today()}`);
  lines.push('');
  lines.push(`**Mode:** ${report.mode}`);
  lines.push(`**Active agents:** ${activeAgents.length > 0 ? activeAgents.join(', ') : 'none'}`);
  lines.push('');
  lines.push('## Metrics');
  lines.push('');
  if (filled.length === 0) {
    lines.push('_No filled orders yet. Start trading to generate metrics._');
  } else {
    lines.push(`| Metric | Value |`);
    lines.push(`|--------|-------|`);
    lines.push(`| Total PnL | $${report.metrics.total_pnl.toFixed(2)} |`);
    lines.push(`| Win Rate | ${report.metrics.win_rate}% |`);
    lines.push(`| Max Drawdown | ${report.metrics.max_drawdown}% |`);
    lines.push(`| Filled Orders | ${report.metrics.filled} |`);
    lines.push(`| Wins / Losses | ${report.metrics.wins} / ${report.metrics.losses} |`);
  }
  lines.push('');

  if (violations.length > 0) {
    lines.push('## Violations');
    lines.push('');
    for (const v of violations) {
      lines.push(`- ${v}`);
    }
    lines.push('');
  }

  // Next actions
  lines.push('## Next Actions');
  lines.push('');
  if (activeAgents.length === 0) {
    lines.push('1. Hire agents: `/hire risk-manager` then `/hire market-maker`');
  } else if (!risk.risk_manager_hired) {
    lines.push('1. **Hire a risk manager** — trading without risk oversight is dangerous');
  }
  if (filled.length === 0) {
    lines.push('1. Place your first paper trade to start generating metrics');
  }
  if (winRate < 0.45 && filled.length >= 5) {
    lines.push('1. Review underperforming agents with `/review`');
  }
  if (firedAgents.length > 0) {
    lines.push(`1. Consider replacements for fired agents: ${firedAgents.map(a => a.slug).join(', ')}`);
  }
  lines.push('');

  report.summary_md = lines.join('\n');

  if (format === 'md') {
    console.log(lines.join('\n'));
  } else {
    console.log(JSON.stringify(report, null, 2));
  }
}

// CLI
const [,, cmd, ...args] = process.argv;
switch (cmd) {
  case 'hire':  hire(args[0]); break;
  case 'fire':  fire(args[0], args.slice(1).join(' ')); break;
  case 'update': update(args[0], args[1], args.slice(2).join(' ')); break;
  case 'show':  show(); break;
  case 'health': health(args[0]); break;
  default:
    console.error('Usage: desk-state <hire|fire|update|show|health> [args]');
    process.exit(1);
}
